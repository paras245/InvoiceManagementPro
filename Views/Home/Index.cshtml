@{
    ViewBag.Title = "Home Page";
}

<div class="hero-section">
    <div class="container">
        <h1>Streamline Your Business Finances</h1>
        <p>Manage Invoices, Customers, and Products with ease and efficiency.</p>
        <a href="@Url.Action("Index", "Bill")" class="btn btn-hero">Manage Invoices</a>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4">
        <!-- Product Card -->
        <div class="col-md-4">
            <a href="@Url.Action("Index", "Product")" style="text-decoration:none">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa fa-cubes"></i>
                    </div>
                    <h3 class="feature-title">Products</h3>
                    <p class="feature-desc">Manage your product inventory, set rates, and track stock effortlessly.</p>
                    <span class="btn btn-outline-primary rounded-pill">Manage Products</span>
                </div>
            </a>
        </div>

        <!-- Customer Card -->
        <div class="col-md-4">
            <a href="@Url.Action("Index", "Customer")" style="text-decoration:none">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa fa-users"></i>
                    </div>
                    <h3 class="feature-title">Customers</h3>
                    <p class="feature-desc">Keep track of your client details and communication history in one place.</p>
                    <span class="btn btn-outline-primary rounded-pill">Manage Customers</span>
                </div>
            </a>
        </div>

        <!-- Bill Card -->
        <div class="col-md-4">
            <a href="@Url.Action("Index", "Bill")" style="text-decoration:none">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa fa-file-text-o"></i>
                    </div>
                    <h3 class="feature-title">Bills & Invoices</h3>
                    <p class="feature-desc">Generate professional invoices and track payments with ease.</p>
                    <span class="btn btn-outline-primary rounded-pill">Manage Bills</span>
                </div>
            </a>
        </div>
    </div>
</div>



