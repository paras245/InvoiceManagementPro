@model InvoiceManagementPro.Models.Customer

@{
    ViewData["Title"] = "Create Customer";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3" style="background: linear-gradient(45deg, #1cc88a, #13855c); color: white;">
                <h6 class="m-0 font-weight-bold">Add Customer</h6>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="CustomerName" class="form-label fw-bold">Customer Name</label>
                        <input asp-for="CustomerName" class="form-control" placeholder="Enter name" />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-bold">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CustomerCity" class="form-label fw-bold">City</label>
                        <input asp-for="CustomerCity" class="form-control" placeholder="Enter city" />
                        <span asp-validation-for="CustomerCity" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CustomerDetail" class="form-label fw-bold">Details (Address)</label>
                        <textarea asp-for="CustomerDetail" class="form-control" rows="3" placeholder="Enter address details"></textarea>
                        <span asp-validation-for="CustomerDetail" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                        <button type="submit" class="btn btn-success"><i class="fa fa-save"></i> Save</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="fa fa-arrow-left"></i> Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
