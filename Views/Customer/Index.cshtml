@model List<InvoiceManagementPro.Models.Customer>

@{
    ViewData["Title"] = "Customer List";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between" style="background: linear-gradient(45deg, #1cc88a, #13855c); color: white;">
            <h6 class="m-0 font-weight-bold text-white">Customer List</h6>
            <div class="d-flex align-items-center">
                <a class="btn btn-light btn-sm me-2 text-success fw-bold" href="@Url.Action("Create")">
                    <i class="fa fa-plus"></i> Create New
                </a>
                <form method="post" asp-controller="Customer" asp-action="Export" class="d-inline">
                     <button class="btn btn-light btn-sm text-danger fw-bold" type="submit">
                         <i class="fa fa-file-excel-o"></i> Export
                     </button>
                </form>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover" id="Customer" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Detail</th>
                            <th>City</th>
                            <th>Phone Number</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td class="align-middle">@customer.CustomerName</td>
                                <td class="align-middle">@customer.CustomerDetail</td>
                                <td class="align-middle">@customer.CustomerCity</td>
                                <td class="align-middle">@customer.PhoneNumber</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a class="btn btn-info btn-sm text-white" href="@Url.Action("Details", new { id = customer.CustomerId })" title="Details">
                                            <i class="fa fa-info-circle"></i>
                                        </a>
                                        <a class="btn btn-warning btn-sm text-white" href="@Url.Action("Edit", new { id = customer.CustomerId })" title="Edit">
                                            <i class="fa fa-pencil"></i>
                                        </a>
                                        <button class="btn btn-danger btn-sm" onclick="confirmDelete('@Url.Action("Delete", new { id = customer.CustomerId })')" title="Delete">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#Customer').DataTable({
                "pageLength": 10,
                "language": {
                    "paginate": {
                        "previous": "<i class='fa fa-angle-left'></i>",
                        "next": "<i class='fa fa-angle-right'></i>"
                    }
                }
            });
        });

        function confirmDelete(url) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            })
        }
    </script>
}
