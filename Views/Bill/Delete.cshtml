@model InvoiceManagementPro.Models.Bill

@{
    ViewData["Title"] = "Delete Invoice";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="dash-card border border-danger border-opacity-25">
            <div class="dash-card-header pb-2" style="border-bottom: 1px solid var(--border-color);">
                <div class="d-flex align-items-center">
                    <h3 class="dash-card-title m-0 text-danger"><i class="fa-solid fa-triangle-exclamation me-2"></i> Delete Invoice</h3>
                </div>
            </div>
            
            <div class="card-body pt-4">
                <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 mb-4" role="alert">
                    <i class="fa-solid fa-trash-can me-2"></i> <strong>Hard Deletion Warning!</strong> You are about to permanently delete this invoice and all of its associated product line items.
                </div>

                <div class="bg-light p-4 rounded border mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bold text-dark m-0">@Model.InvoiceNumber</h4>
                        <span class="badge bg-secondary text-white px-3 py-2 rounded-pill">@Model.Status</span>
                    </div>
                    
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-semibold">Billed To</div>
                        <div class="col-sm-8 fw-bold">@(Model.Customer?.CustomerName ?? "Unknown")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted fw-semibold">Date Created</div>
                        <div class="col-sm-8 fw-bold">@Model.BillCreatedDate.ToString("dd MMM yyyy")</div>
                    </div>
                    
                     <div class="row mt-3 pt-3" style="border-top: 1px dashed var(--border-color);">
                        <div class="col-sm-4 text-muted fw-semibold fs-5 align-self-center">Grand Total</div>
                        <div class="col-sm-8 fw-bold fs-3 text-primary">₹@Model.GrandTotalAmount.ToString("N2")</div>
                    </div>
                </div>

                <form asp-action="Delete" class="d-flex gap-2">
                    <input type="hidden" asp-for="BillId" />
                    <a href="@Url.Action("Index")" class="btn btn-light border fw-semibold flex-grow-1">Cancel</a>
                    <button type="submit" class="btn btn-danger fw-semibold flex-grow-1"><i class="fa-solid fa-trash me-2"></i> Confirm Deletion</button>
                </form>
            </div>
        </div>
    </div>
</div>
