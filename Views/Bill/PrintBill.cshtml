@model InvoiceManagementPro.Models.BillView

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice - @Model.CustomerName</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #555;
            margin: 0;
            padding: 20px;
            background-color: #f5f5f5;
        }
        .invoice-box {
            max-width: 800px;
            margin: auto;
            padding: 30px;
            border: 1px solid #eee;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
            font-size: 16px;
            line-height: 24px;
            background-color: #fff;
            color: #555;
        }
        .invoice-box table {
            width: 100%;
            line-height: inherit;
            text-align: left;
            border-collapse: collapse;
        }
        .invoice-box table td {
            padding: 5px;
            vertical-align: top;
        }
        .invoice-box table tr.top table td {
            padding-bottom: 20px;
        }
        .invoice-box table tr.top table td.title {
            font-size: 45px;
            line-height: 45px;
            color: #333;
        }
        .invoice-box table tr.information table td {
            padding-bottom: 40px;
        }
        .invoice-box table tr.heading td {
            background: #eee;
            border-bottom: 1px solid #ddd;
            font-weight: bold;
        }
        .invoice-box table tr.details td {
            padding-bottom: 20px;
        }
        .invoice-box table tr.item td {
            border-bottom: 1px solid #eee;
        }
        .invoice-box table tr.item.last td {
            border-bottom: none;
        }
        .invoice-box table tr.total td:nth-child(2) {
            border-top: 2px solid #eee;
            font-weight: bold;
        }
        .text-right {
            text-align: right;
        }
        .center {
            text-align: center;
        }
        .btn-print {
            background-color: #4CAF50;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            margin-top: 20px;
            display: block;
            margin-left: auto;
            margin-right: auto;
        }
        .btn-print:hover {
            background-color: #45a049;
        }
        .qr-code {
            margin-top: 20px;
            text-align: center;
        }
        .qr-code img {
            max-width: 150px;
        }

        @@media only screen and (max-width: 600px) {
            .invoice-box table tr.top table td {
                width: 100%;
                display: block;
                text-align: center;
            }
            .invoice-box table tr.information table td {
                width: 100%;
                display: block;
                text-align: center;
            }
        }

        /** RTL **/
        .rtl {
            direction: rtl;
            font-family: Tahoma, 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
        }
        .rtl table {
            text-align: right;
        }
        .rtl table tr td:nth-child(2) {
            text-align: left;
        }

        @@media print {
            .btn-print {
                display: none;
            }
            body {
                background-color: #fff;
            }
            .invoice-box {
                box-shadow: none;
                border: none;
            }
        }
    </style>
</head>
<body>
    <div class="invoice-box">
        <table cellpadding="0" cellspacing="0">
            <tr class="top">
                <td colspan="5">
                    <table>
                        <tr>
                            <td class="title">
                                <h2 style="color: #4e73df; margin:0;">INVOICE</h2>
                                <span style="font-size: 14px; color: #888;">Invoice Management Pro</span>
                            </td>
                            <td class="text-right">
                                Invoice #: @Model.BillId<br />
                                Created: @Model.BillCreatedDate?.ToString("MMMM dd, yyyy")<br />
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>

            <tr class="information">
                <td colspan="5">
                    <table>
                        <tr>
                            <td>
                                <strong>Bill To:</strong><br />
                                @Model.CustomerName<br />
                                @* Mock Address if not available *@
                                123 Business Rd.<br />
                                City, State 12345
                            </td>
                            <td class="text-right">
                                <strong>Company:</strong><br />
                                Invoice Management Pro Ltd.<br />
                                admin@invoicepro.com
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>

            <tr class="heading">
                <td colspan="2">Item</td>
                <td class="text-right">Unit Price</td>
                <td class="text-right">Quantity</td>
                <td class="text-right">Total</td>
            </tr>

            <tr class="item">
                <td colspan="2">@Model.ProductName</td>
                <td class="text-right">@string.Format("{0:C}", Model.ProductRate)</td>
                <td class="text-right">@Model.ProductQuantity</td>
                <td class="text-right">@string.Format("{0:C}", Model.TotalAmount)</td>
            </tr>
            
            @* GST Calculation *@
            @{
                var gstAmount = Model.TotalAmount * 0.18;
                var grandTotal = Model.TotalAmount + gstAmount;
            }

             <tr class="item">
                <td colspan="4" class="text-right">Subtotal:</td>
                <td class="text-right">@string.Format("{0:C}", Model.TotalAmount)</td>
            </tr>
             <tr class="item">
                <td colspan="4" class="text-right">GST (18%):</td>
                <td class="text-right">@string.Format("{0:C}", gstAmount)</td>
            </tr>

            <tr class="total">
                <td colspan="4" class="text-right"><strong>Grand Total:</strong></td>
                <td class="text-right"><strong>@string.Format("{0:C}", grandTotal)</strong></td>
            </tr>
        </table>
        
        <div class="qr-code">
            @if (!string.IsNullOrEmpty(Model.QRCodeImage))
            {
                <img src="@Model.QRCodeImage" alt="QR Code" />
            }
        </div>
        
        <div class="center" style="margin-top: 30px; font-style: italic; color: #888;">
            <p>Thank you for your business!</p>
        </div>
    </div>

    <button class="btn-print" onclick="window.print()">Print Invoice</button>
</body>
</html>
