@model List<InvoiceManagementPro.Models.BillView>

@{
    ViewData["Title"] = "Bill List";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between" style="background: linear-gradient(45deg, #36b9cc, #2c9faf); color: white;">
            <h6 class="m-0 font-weight-bold text-white">Bill List</h6>
            <div class="d-flex align-items-center">
                <a class="btn btn-light btn-sm fw-bold text-info" href="@Url.Action("Create")">
                    <i class="fa fa-plus"></i> Create New
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover" id="Bill" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Qty</th>
                            <th>Item</th>
                            <th class="text-center" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model)
                        {
                            <tr>
                                <td class="align-middle">@bill.CustomerName</td>
                                <td class="align-middle">@bill.TotalAmount</td>
                                <td class="align-middle">@bill.BillCreatedDate?.ToString("dd/MM/yyyy")</td>
                                <td class="align-middle">@bill.ProductQuantity</td>
                                <td class="align-middle">@bill.ProductName</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a class="btn btn-primary btn-sm" href="@Url.Action("PrintBill", new { id = bill.BillId })" title="Print Invoice">
                                            <i class="fa fa-print"></i>
                                        </a>
                                        <a class="btn btn-info btn-sm text-white" href="@Url.Action("Details", new { id = bill.BillId })" title="Details">
                                            <i class="fa fa-info-circle"></i>
                                        </a>
                                        <a class="btn btn-warning btn-sm text-white" href="@Url.Action("Edit", new { id = bill.BillId })" title="Edit">
                                            <i class="fa fa-pencil"></i>
                                        </a>
                                        <button class="btn btn-danger btn-sm" onclick="confirmDelete('@Url.Action("Delete", new { id = bill.BillId })')" title="Delete">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#Bill').DataTable({
                "order": [[2, "desc"]], // Sort by Date desc
                "pageLength": 10,
                "language": {
                    "paginate": {
                        "previous": "<i class='fa fa-angle-left'></i>",
                        "next": "<i class='fa fa-angle-right'></i>"
                    }
                }
            });
        });

        function confirmDelete(url) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            })
        }
    </script>
}
