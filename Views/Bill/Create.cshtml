@model InvoiceManagementPro.Models.Bill

@{
    ViewData["Title"] = "Create Bill";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow mb-4">
            <div class="card-header py-3" style="background: linear-gradient(45deg, #36b9cc, #2c9faf); color: white;">
                <h6 class="m-0 font-weight-bold">Create New Bill</h6>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CustomerId" class="form-label fw-bold">Customer</label>
                            <select asp-for="CustomerId" class="form-select" asp-items="@(new SelectList(ViewBag.CustomerList, "Value", "Text"))">
                                <option value="">-- Select Customer --</option>
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ProductQuantity" class="form-label fw-bold">Product</label>
                            <select asp-for="ProductQuantity" class="form-select" asp-items="@(new SelectList(ViewBag.ProductList, "Value", "Text"))">
                                <option value="">-- Select Product --</option>
                            </select>
                            <span asp-validation-for="ProductQuantity" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Quantity" class="form-label fw-bold">Quantity</label>
                            <input asp-for="Quantity" class="form-control" placeholder="Enter quantity" type="number" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="BillCreatedDate" class="form-label fw-bold">Bill Date</label>
                            <input asp-for="BillCreatedDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="BillCreatedDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-3">
                        <button type="submit" class="btn btn-success"><i class="fa fa-save"></i> Save Bill</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="fa fa-arrow-left"></i> Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script type="text/javascript">
        // Basic calculations if needed, though most logic should be handled backend or with Vue/React if complex
        // Keeping it simple for now as per requirements
    </script>
}
