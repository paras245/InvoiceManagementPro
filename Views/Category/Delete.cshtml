@model InvoiceManagementPro.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="dash-card border border-danger border-opacity-25">
            <div class="dash-card-header pb-2" style="border-bottom: 1px solid var(--border-color);">
                <div class="d-flex align-items-center">
                    <h3 class="dash-card-title m-0 text-danger"><i class="fa-solid fa-triangle-exclamation me-2"></i> Delete Category</h3>
                </div>
            </div>
            
            <div class="card-body pt-4">
                <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 mb-4" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> <strong>Warning!</strong> Are you sure you want to delete this category? This will not delete the associated products but it may leave them uncategorized. The category image will be permanently deleted.
                </div>

                <div class="row g-4">
                    <div class="col-md-4 text-center">
                        <div class="bg-light rounded d-flex align-items-center justify-content-center mb-3 border py-2" style="height: 180px; overflow: hidden; opacity: 0.8;">
                             @if (!string.IsNullOrEmpty(Model.ImagePath))
                            {
                                <img src="@Model.ImagePath" alt="Thumbnail" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="text-center text-muted">
                                    <i class="fa-solid fa-shapes mb-2" style="font-size: 3rem;"></i>
                                    <p class="mb-0">No Image</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-md-8 ps-md-4 align-self-center">
                        <h4 class="fw-bold text-dark mb-3">@Model.CategoryName</h4>
                        
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-semibold">Description</div>
                            <div class="col-sm-8 fw-bold">@(string.IsNullOrEmpty(Model.Description) ? "N/A" : Model.Description)</div>
                        </div>
                        
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-semibold">Status</div>
                            <div class="col-sm-8 fw-bold">@Model.Status</div>
                        </div>
                        
                        <hr class="my-4" style="border-color: var(--border-color); opacity: 1;">
                        
                        <form asp-action="Delete" class="d-flex gap-2">
                            <input type="hidden" asp-for="CategoryId" />
                            <a href="@Url.Action("Index")" class="btn btn-light border fw-semibold flex-grow-1">Cancel</a>
                            <button type="submit" class="btn btn-danger fw-semibold flex-grow-1"><i class="fa-solid fa-trash me-2"></i> Confirm Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
