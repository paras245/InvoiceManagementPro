@model InvoiceManagementPro.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="dash-card">
            <div class="dash-card-header pb-2" style="border-bottom: 1px solid var(--border-color);">
                <h3 class="dash-card-title m-0"><i class="fa-solid fa-folder-plus me-2 text-primary"></i> Add New Category</h3>
            </div>
            
            <div class="card-body pt-4">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="CategoryName" class="form-label fw-semibold">Category Name <span class="text-danger">*</span></label>
                        <input asp-for="CategoryName" class="form-control" placeholder="e.g., Electronics, Hardware" />
                        <span asp-validation-for="CategoryName" class="text-danger" style="font-size:0.85rem;"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Status <span class="text-danger">*</span></label>
                        <div class="d-flex gap-4 mt-1">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="Status" value="Active" id="statusActive" checked>
                                <label class="form-check-label" for="statusActive">
                                    <span class="badge bg-success bg-opacity-10 text-success p-2 px-3 rounded-pill">Active</span>
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="Status" value="Inactive" id="statusInactive">
                                <label class="form-check-label" for="statusInactive">
                                    <span class="badge bg-danger bg-opacity-10 text-danger p-2 px-3 rounded-pill">Inactive</span>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Status" class="text-danger" style="font-size:0.85rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Category details..."></textarea>
                        <span asp-validation-for="Description" class="text-danger" style="font-size:0.85rem;"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImageUpload" class="form-label fw-semibold" style="font-size:0.9rem;">Category Thumbnail</label>
                        <input asp-for="ImageUpload" type="file" class="form-control form-control-sm" accept="image/*" />
                        <small class="text-muted d-block mt-1">Accepted formats: JPG, PNG, WEBP. Max 2MB.</small>
                    </div>

                    <hr class="my-4" style="border-color: var(--border-color); opacity: 1;">
                    
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light border fw-semibold">Cancel</a>
                        <button type="submit" class="btn btn-primary fw-semibold"><i class="fa-solid fa-check me-1"></i> Create Category</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
