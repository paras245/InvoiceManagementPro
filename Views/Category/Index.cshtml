@model IEnumerable<InvoiceManagementPro.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="dash-card">
    <div class="dash-card-header mb-4">
        <h3 class="dash-card-title m-0">Product Categories</h3>
        <div class="d-flex gap-2">
            <a class="btn btn-primary btn-sm fw-semibold" asp-action="Create">
                <i class="fa fa-plus me-1"></i> Add Category
            </a>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle" id="CategoryTable" width="100%" cellspacing="0">
            <thead class="bg-light text-muted" style="font-size:0.85rem; text-transform:uppercase;">
                <tr>
                    <th style="width: 60px;">Image</th>
                    <th>Category Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th class="text-end" style="width: 120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td>
                            <div style="width: 48px; height: 48px; border-radius: 8px; overflow: hidden; background-color: #f1f5f9; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border-color);">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="@item.ImagePath" alt="@item.CategoryName" style="width: 100%; height: 100%; object-fit: cover;" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-shapes text-muted" style="font-size: 1.2rem;"></i>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@item.CategoryName</div>
                        </td>
                        <td>
                            <small class="text-muted text-truncate d-inline-block" style="max-width: 300px;">
                                @(string.IsNullOrEmpty(item.Description) ? "-" : item.Description)
                            </small>
                        </td>
                        <td>
                            @if (item.Status == "Active")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2"><i class="fa-solid fa-check-circle me-1" style="font-size: 0.6rem;"></i> Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2"><i class="fa-solid fa-times-circle me-1" style="font-size: 0.6rem;"></i> Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-light text-primary me-1" asp-action="Details" asp-route-id="@item.CategoryId" title="Details">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a class="btn btn-sm btn-light text-warning me-1" asp-action="Edit" asp-route-id="@item.CategoryId" title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-light text-danger" onclick="confirmDelete('@Url.Action("Delete", new { id = item.CategoryId })')" title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#CategoryTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search categories...",
                    "paginate": {
                        "previous": "Prev",
                        "next": "Next"
                    }
                },
                "dom": '<"row align-items-center mb-3"<"col-md-6"l><"col-md-6"f>>rt<"row align-items-center mt-3"<"col-md-6"i><"col-md-6"p>>'
            });
            
            $('.dataTables_filter input').addClass('form-control form-control-sm border');
            $('.dataTables_length select').addClass('form-select form-select-sm border');
        });

        function confirmDelete(url) {
            Swal.fire({
                title: 'Delete Category?',
                text: "Deleting a category will NOT delete the associated products, but it will orphan them. Image associated with category will be removed.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e3342f',
                cancelButtonColor: '#858796',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.createElement("form");
                    form.setAttribute("method", "post");
                    form.setAttribute("action", url);
                    
                    var antiforgery = document.querySelector('input[name="__RequestVerificationToken"]');
                    if(antiforgery) {
                        form.appendChild(antiforgery.cloneNode(true));
                    }

                    document.body.appendChild(form);
                    form.submit();
                }
            })
        }
    </script>
}
