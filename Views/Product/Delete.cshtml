@model InvoiceManagementPro.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="dash-card border border-danger border-opacity-25">
            <div class="dash-card-header pb-2" style="border-bottom: 1px solid var(--border-color);">
                <div class="d-flex align-items-center">
                    <h3 class="dash-card-title m-0 text-danger"><i class="fa-solid fa-triangle-exclamation me-2"></i> Delete Product</h3>
                </div>
            </div>
            
            <div class="card-body pt-4">
                <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 mb-4" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> <strong>Warning!</strong> Are you sure you want to delete this product? This action cannot be undone and all associated images will be permanently removed constraints permitting.
                </div>

                <div class="row g-4">
                    <!-- Left Column: Images -->
                    <div class="col-md-5">
                        <div class="bg-light rounded d-flex align-items-center justify-content-center mb-3 border py-2" style="height: 250px; overflow: hidden; opacity: 0.8;">
                             @if (!string.IsNullOrEmpty(Model.ImagePath1))
                            {
                                <img src="@Model.ImagePath1" alt="Primary Image" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="text-center text-muted">
                                    <i class="fa-solid fa-image mb-2" style="font-size: 3rem;"></i>
                                    <p class="mb-0">No Primary Image</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Right Column: Info -->
                    <div class="col-md-7 ps-md-4">
                        <h4 class="fw-bold text-dark mb-3">@Model.ProductName</h4>
                        
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-semibold">Category</div>
                            <div class="col-sm-8 fw-bold">@(string.IsNullOrEmpty(Model.Category) ? "Uncategorized" : Model.Category)</div>
                        </div>
                        
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-semibold">Price</div>
                            <div class="col-sm-8 fw-bold text-dark">AED @Model.ProductRate.ToString("N2") <span class="text-muted fw-normal">/ @Model.ProductUnit</span></div>
                        </div>
                        
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted fw-semibold">Status</div>
                            <div class="col-sm-8 fw-bold">@Model.Status</div>
                        </div>
                        
                        <hr class="my-4" style="border-color: var(--border-color); opacity: 1;">
                        
                        <form asp-action="Delete" class="d-flex gap-2 mt-4">
                            <input type="hidden" asp-for="ProductId" />
                            <a href="@Url.Action("Index")" class="btn btn-light border fw-semibold flex-grow-1">Cancel</a>
                            <button type="submit" class="btn btn-danger fw-semibold flex-grow-1"><i class="fa-solid fa-trash me-2"></i> Confirm Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
