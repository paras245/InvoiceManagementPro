@model IEnumerable<InvoiceManagementPro.Models.User>

@{
    ViewData["Title"] = "Employees";
}

<div class="dash-card">
    <div class="dash-card-header mb-4">
        <h3 class="dash-card-title m-0">Employee Directory</h3>
        <div class="d-flex gap-2">
            <a class="btn btn-primary btn-sm fw-semibold" asp-action="Create">
                <i class="fa fa-user-plus me-1"></i> Add Employee
            </a>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle" id="UserTable" width="100%" cellspacing="0">
            <thead class="bg-light text-muted" style="font-size:0.85rem; text-transform:uppercase;">
                <tr>
                    <th style="width: 60px;">Profile</th>
                    <th>Employee Details</th>
                    <th>Role & Type</th>
                    <th>Contact</th>
                    <th>Status</th>
                    <th class="text-end" style="width: 120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td>
                            <div style="width: 48px; height: 48px; border-radius: 50%; overflow: hidden; background-color: #f1f5f9; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border-color);">
                                @if (!string.IsNullOrEmpty(item.ProfileImagePath))
                                {
                                    <img src="@item.ProfileImagePath" alt="@item.FullName" style="width: 100%; height: 100%; object-fit: cover;" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-user text-muted" style="font-size: 1.2rem;"></i>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="fw-bold text-dark mb-1">@item.FullName</div>
                            <small class="text-muted d-block"><i class="fa-regular fa-calendar-alt me-1"></i> Joined: @item.DateOfJoining.ToString("MMM dd, yyyy")</small>
                        </td>
                        <td>
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-1 mb-1 d-inline-block">@item.Role</span><br/>
                            <small class="text-muted">@item.EmploymentType</small>
                        </td>
                        <td>
                            <small class="d-block text-dark"><i class="fa-solid fa-envelope text-muted me-1"></i> @item.Email</small>
                            <small class="d-block text-dark mt-1"><i class="fa-solid fa-phone text-muted me-1"></i> @item.PhoneNumber</small>
                        </td>
                        <td>
                            @if (item.Status == "Active")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2"><i class="fa-solid fa-user-check me-1" style="font-size: 0.6rem;"></i> Active</span>
                            }
                            else if (item.Status == "Suspended")
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2"><i class="fa-solid fa-user-slash me-1" style="font-size: 0.6rem;"></i> Suspended</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2"><i class="fa-solid fa-user-times me-1" style="font-size: 0.6rem;"></i> Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-light text-primary me-1" asp-action="Details" asp-route-id="@item.UserId" title="Details">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a class="btn btn-sm btn-light text-warning me-1" asp-action="Edit" asp-route-id="@item.UserId" title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-light text-danger" onclick="confirmDelete('@Url.Action("Delete", new { id = item.UserId })')" title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#UserTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search employees...",
                    "paginate": {
                        "previous": "Prev",
                        "next": "Next"
                    }
                },
                "dom": '<"row align-items-center mb-3"<"col-md-6"l><"col-md-6"f>>rt<"row align-items-center mt-3"<"col-md-6"i><"col-md-6"p>>'
            });
            
            $('.dataTables_filter input').addClass('form-control form-control-sm border');
            $('.dataTables_length select').addClass('form-select form-select-sm border');
        });

        function confirmDelete(url) {
            Swal.fire({
                title: 'Terminate Employee Record?',
                text: "This action cannot be undone. Profile data and associated images will be permanently removed.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e3342f',
                cancelButtonColor: '#858796',
                confirmButtonText: 'Yes, delete record!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.createElement("form");
                    form.setAttribute("method", "post");
                    form.setAttribute("action", url);
                    
                    var antiforgery = document.querySelector('input[name="__RequestVerificationToken"]');
                    if(antiforgery) {
                        form.appendChild(antiforgery.cloneNode(true));
                    }

                    document.body.appendChild(form);
                    form.submit();
                }
            })
        }
    </script>
}
