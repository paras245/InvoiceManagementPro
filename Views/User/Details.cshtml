@model InvoiceManagementPro.Models.User

@{
    ViewData["Title"] = "Employee Profile";
}

<div class="row g-4 justify-content-center">
    <div class="col-lg-4">
        <div class="dash-card mb-4 text-center">
            <div class="card-body py-5">
                <div class="mb-3">
                    @if(!string.IsNullOrEmpty(Model.ProfileImagePath))
                    {
                        <img src="@Model.ProfileImagePath" alt="Profile" style="height:150px; width:150px; object-fit:cover; border-radius:50%; border:4px solid #f1f5f9; box-shadow: 0 4px 15px rgba(0,0,0,0.1);"/>
                    }
                    else 
                    {
                        <i class="fa-solid fa-circle-user text-muted" style="font-size: 8rem;"></i>
                    }
                </div>
                <h4 class="fw-bold text-dark m-0">@Model.FullName</h4>
                <p class="text-muted mb-3">@Model.Role</p>
                
                <div class="d-flex justify-content-center gap-2 mb-4">
                     @if (Model.Status == "Active")
                     {
                         <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">Active</span>
                     }
                     else if (Model.Status == "Suspended")
                     {
                         <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2">Suspended</span>
                     }
                     else 
                     {
                         <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2">Inactive</span>
                     }
                </div>

                <div class="d-flex justify-content-center gap-2">
                     <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary fw-semibold btn-sm px-4">Edit Profile</a>
                     <a href="mailto:@Model.Email" class="btn btn-light border fw-semibold btn-sm px-3"><i class="fa-solid fa-envelope"></i></a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="dash-card h-100">
            <div class="dash-card-header pb-2" style="border-bottom: 1px solid var(--border-color);">
                <div class="d-flex align-items-center">
                    <a href="@Url.Action("Index")" class="btn btn-sm btn-light me-3"><i class="fa-solid fa-arrow-left"></i></a>
                    <h4 class="dash-card-title m-0">Profile Overview</h4>
                </div>
            </div>
            
            <div class="card-body pt-4">
                <h6 class="fw-bold text-primary mb-3 text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Personal Information</h6>
                <div class="row mb-4">
                    <div class="col-sm-6 mb-3 mb-sm-0">
                        <small class="text-muted d-block fw-semibold mb-1">Full Name</small>
                        <div class="fw-bold text-dark">@Model.FullName</div>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block fw-semibold mb-1">Gender</small>
                        <div class="fw-bold text-dark">@Model.Gender</div>
                    </div>
                </div>
                
                <div class="row mb-4">
                    <div class="col-sm-6 mb-3 mb-sm-0">
                        <small class="text-muted d-block fw-semibold mb-1">Email Address</small>
                        <div class="fw-bold text-dark">@Model.Email</div>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block fw-semibold mb-1">Phone Number</small>
                        <div class="fw-bold text-dark">@Model.PhoneNumber</div>
                    </div>
                </div>

                <div class="row mb-5">
                    <div class="col-12">
                        <small class="text-muted d-block fw-semibold mb-1">Physical Address</small>
                        <div class="fw-bold text-dark">@(string.IsNullOrEmpty(Model.Address) ? "N/A" : Model.Address)</div>
                    </div>
                </div>

                <h6 class="fw-bold text-primary mb-3 text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Employment Information</h6>
                <div class="row mb-4">
                    <div class="col-sm-6 mb-3 mb-sm-0">
                        <small class="text-muted d-block fw-semibold mb-1">Role / Designaton</small>
                        <div class="fw-bold text-dark">@Model.Role</div>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block fw-semibold mb-1">Employment Type</small>
                        <div class="fw-bold text-dark">@Model.EmploymentType</div>
                    </div>
                </div>
                
                <div class="row mb-2">
                    <div class="col-sm-6 mb-3 mb-sm-0">
                        <small class="text-muted d-block fw-semibold mb-1">Date of Joining</small>
                        <div class="fw-bold text-dark">@Model.DateOfJoining.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block fw-semibold mb-1">Employee ID</small>
                        <div class="fw-bold text-dark">#EMP-@Model.UserId.ToString("D4")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
